# AgroChain Frontend — Environment Variables
# Copy to .env.local and fill in deployed contract addresses.

# Wallet Connect (get from https://cloud.walletconnect.com/)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Avalanche RPC
VITE_AVALANCHE_RPC=https://api.avax-test.network/ext/bc/C/rpc

# Deployed contract addresses (run: cd contracts && npx hardhat run scripts/deploy.js --network fuji)
VITE_POLICY_VAULT_ADDRESS=0x...
VITE_LIQUIDITY_POOL_ADDRESS=0x...
VITE_ORACLE_CONSUMER_ADDRESS=0x...

# USDC token address
# Fuji testnet MockUSDC: set to address output by deploy.js
# Avalanche mainnet: 0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6
VITE_USDC_ADDRESS=0x...

# Mapbox (Block 4 — optional for now)
# VITE_MAPBOX_ACCESS_TOKEN=pk...
